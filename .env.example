# =============================================================
# DivisionX Card — Environment Variables Example
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
# สำคัญ: ห้าม commit ไฟล์ .env ขึ้น Git เด็ดขาด!
# =============================================================

# ─── VMS InboxCorp Credentials ───────────────────────────────
# ข้อมูล Login สำหรับดึงยอดขายจากระบบ VMS
VMS_URL=https://vms.inboxcorp.co.th/th/login
VMS_USERNAME=your_vms_username_here
VMS_PASSWORD=your_vms_password_here

# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string
# รูปแบบ: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/divisionx_card

# สำหรับ Supabase (ถ้าใช้)
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api

# ─── Authentication (JWT) ────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_NAME=DivisionX Card

# ─── VMS Sync Schedule (Cron) ────────────────────────────────
# กำหนดเวลา sync ข้อมูลจาก VMS อัตโนมัติ
# ค่า default: ทุก 6 ชั่วโมง
VMS_SYNC_CRON=0 */6 * * *

# ─── Timezone ────────────────────────────────────────────────
TZ=Asia/Bangkok
